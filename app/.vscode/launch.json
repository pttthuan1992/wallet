{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: Uvicorn",
            "type": "debugpy", // Use "debugpy" instead of "python"
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app", // Replace "main:app" with your actual app entry point (e.g., "src.main:app")
                "--reload",
            ],
            "console": "integratedTerminal"
        }
    ]
}
